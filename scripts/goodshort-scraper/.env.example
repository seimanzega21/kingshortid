# GoodShort API Configuration
# Copy this to .env and fill in your values

# Bearer token from HTTP Toolkit capture
GOODSHORT_AUTH_TOKEN=Bearer YOUR_TOKEN_HERE

# Database URL (same as KingShortID backend)
DATABASE_URL=postgresql://user:password@localhost:5432/kingshortid

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=kingshortid
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# API Settings
GOODSHORT_API_BASE=https://api-akm.goodreels.com/hwyclientreels
