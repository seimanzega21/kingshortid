border: 1px solid #00aad5;
min-width: max-content;
margin-top: 0;
color: #00aad5;
font-size: 10px;
text-transform: uppercase;
padding: 10px;
background: transparent;
order: 3;
opacity: 1;
transition: opacity 1s ease;
@starting-style {
